{
  "expo": {
    "name": "NaamSmaran",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.emergent.bhaktidaily.fhcrgp",
      "infoPlist": {
        "NSUserNotificationUsageDescription": "Send japa reminders throughout the day"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFFDF9"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.emergent.bhaktidaily.fhcrgp",
      "permissions": [
        "SCHEDULE_EXACT_ALARM",
        "USE_EXACT_ALARM",
        "POST_NOTIFICATIONS",
        "VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFFDF9"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#E57A00"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
